# Paperless-ngx stack env vars (set these in Portainer stack Environment).

# Postgres password shared by the db and webserver services.
POSTGRES_PASSWORD=change-me

# Django SECRET_KEY. Generate with:
#   openssl rand -base64 48
PAPERLESS_SECRET_KEY=change-me

# Bootstrap admin account (created on first run only). Change via web UI after
# first login — updating these env vars later has no effect.
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=change-me
