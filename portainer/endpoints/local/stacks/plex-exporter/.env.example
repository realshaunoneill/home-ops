# Copy into the plex-exporter stack's Environment variables in Portainer.
# Do NOT commit real token values.
#
# PLEX_TOKEN is the X-Plex-Token from your server. Find it via:
#   - grep PlexOnlineToken in /config/Library/Application Support/Plex Media
#     Server/Preferences.xml inside the plex container, or
#   - open any item in Plex → three-dot menu → Get Info → View XML → look for
#     `X-Plex-Token=...` in the URL.

PLEX_TOKEN=change-me
