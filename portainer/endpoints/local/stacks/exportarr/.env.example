# Copy these into the exportarr stack's Environment variables in Portainer
# (do NOT commit real values). Each *arr's API key can be found in the
# corresponding app's UI at: Settings → General → Security → API Key.

RADARR_API_KEY=change-me
SONARR_API_KEY=change-me
PROWLARR_API_KEY=change-me
BAZARR_API_KEY=change-me
