# Copy these into the Grafana stack's Environment variables in Portainer
# (do not commit a real .env). Values here are placeholders.

# Admin login used on first boot. If GF_SECURITY_ADMIN_PASSWORD is empty,
# Grafana falls back to the default admin/admin and forces a password change
# at first login.
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me
