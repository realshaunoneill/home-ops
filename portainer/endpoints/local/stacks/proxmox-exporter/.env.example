# Copy these into the proxmox-exporter stack's Environment variables in Portainer.
# Do NOT commit real values.
#
# PVE_USER example: root@pam
# PVE_TOKEN_NAME example: Claude
# PVE_TOKEN_VALUE: token secret generated in Proxmox
# PVE_VERIFY_SSL: set false if using self-signed TLS on :8006

PVE_USER=root@pam
PVE_TOKEN_NAME=change-me
PVE_TOKEN_VALUE=change-me
PVE_VERIFY_SSL=false
